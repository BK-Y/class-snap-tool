# Example environment variables for class-snap-tool
# Copy to `.env` (used by python-dotenv if you choose to install it) or
# set them directly in your deployment environment.

# flask configuration
SECRET_KEY=your-secret-key-here
FLASK_ENV=development   # or 'production'
DEBUG=1                # 0/1 or true/false

# database
# for sqlite you can use a relative or absolute path. e.g.:
DATABASE_PATH=.data/school.db

# optional override of host/port (run.py also supports CLI args)
HOST=127.0.0.1
PORT=5000
